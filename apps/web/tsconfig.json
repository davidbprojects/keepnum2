{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "outDir": "build",
    "rootDir": "src",
    "noEmit": true,
    "isolatedModules": true,
    "allowJs": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "build"]
}
